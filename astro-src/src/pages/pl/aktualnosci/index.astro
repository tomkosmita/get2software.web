---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { canonicalUrl } from '../../../lib/seo/site';
import { routeMap } from '../../../lib/i18n/routes';

const pathname = '/pl/aktualnosci/';
const title = 'Aktualności - get2software.com';
const description = 'Publikujemy materiały o produktach, wdrożeniach, integracjach i procesach operacyjnych.';
---

<MarketingLayout
  locale="pl"
  title={title}
  description={description}
  pathname={pathname}
  hreflangPl={canonicalUrl(pathname)}
  hreflangEn={canonicalUrl(routeMap.news.en)}
  alternateHref={routeMap.news.en}
  active="news"
>
  <div class="g2-container py-14 md:py-20">
    <h1 class="g2-heading-xl">Aktualności</h1>
    <p class="g2-prose mt-4 max-w-2xl">
      W tej sekcji publikujemy materiały o produktach, wdrożeniach, integracjach i praktyce operacyjnej. Jeśli chcesz
      porozmawiać o konkretnym procesie w swojej firmie, przejdź do kontaktu.
    </p>
    <a href="/pl/kontakt/" class="g2-btn-primary mt-8 inline-flex">Porozmawiajmy</a>
  </div>
</MarketingLayout>
