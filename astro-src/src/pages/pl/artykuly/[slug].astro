---
/**
 * Pojedynczy artykuł Markdown z kolekcji `articles` — render treści przez `render()` (bez MDX w zależnościach).
 */
import { getCollection, render } from 'astro:content';
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { canonicalUrl } from '../../../lib/seo/site';
import { productSlugToRouteKey, routeMap } from '../../../lib/i18n/routes';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug }
  }));
}

const slugParam = Astro.params.slug;
const all = await getCollection('articles');
const post = all.find((e) => e.data.slug === slugParam);
if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);
const { slug } = post.data;

const pathname = `/pl/artykuly/${slug}/`;
const published = post.data.publishedAt.toISOString();
const modified = (post.data.updatedAt ?? post.data.publishedAt).toISOString();

const routeKey = post.data.relatedProductSlug ? productSlugToRouteKey(post.data.relatedProductSlug) : null;
const relatedHref = routeKey ? routeMap[routeKey].pl : undefined;

const articleLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.seoDescription,
  datePublished: published,
  dateModified: modified,
  inLanguage: 'pl-PL',
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl(pathname) },
  author: { '@type': 'Organization', name: 'get2software.com' },
  publisher: {
    '@type': 'Organization',
    name: 'get2software.com',
    url: canonicalUrl('/pl/')
  }
};

if (relatedHref && post.data.relatedProductSlug) {
  articleLd.about = {
    '@type': 'SoftwareApplication',
    name: post.data.relatedProductSlug,
    url: canonicalUrl(relatedHref)
  };
}
---

<MarketingLayout
  locale="pl"
  title={post.data.seoTitle}
  description={post.data.seoDescription}
  pathname={pathname}
  hreflangMode="pl-only"
  hreflangPl={canonicalUrl(pathname)}
  hreflangEn={canonicalUrl(routeMap.home.en)}
  active="articles"
  ogType="article"
  structuredData={[articleLd]}
>
  <article class="g2-container py-14 md:py-20" lang="pl">
    <header class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-g2-accent">{post.data.category}</p>
      <h1 class="g2-heading-xl mt-3">{post.data.title}</h1>
      <p class="g2-prose mt-4 text-lg text-g2-muted">{post.data.lead}</p>
      <p class="mt-6 text-sm text-g2-muted">
        Publikacja:{' '}
        <time datetime={published}>
          {post.data.publishedAt.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.updatedAt && post.data.updatedAt.getTime() !== post.data.publishedAt.getTime() ? (
          <>
            {' '}
            · aktualizacja:{' '}
            <time datetime={modified}>
              {post.data.updatedAt.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </>
        ) : null}
      </p>
    </header>

    <!-- Treść Markdown: styl `.g2-article-prose` nadaje hierarchię wizualną bez pełnego pluginu typography. -->
    <div class="g2-article-prose g2-prose mx-auto mt-12 max-w-3xl">
      <Content />
    </div>

    {post.data.sources && post.data.sources.length > 0 ? (
      <section class="mx-auto mt-14 max-w-3xl border-t border-g2-border pt-10" aria-labelledby="article-sources-heading">
        <h2 id="article-sources-heading" class="font-display text-lg font-semibold text-g2-text">
          Źródła i materiały referencyjne
        </h2>
        <ul class="mt-4 list-inside list-disc space-y-2 text-sm text-g2-muted">
          {post.data.sources.map((s) => (
            <li>
              <a href={s.url} rel="noopener noreferrer" target="_blank" class="font-medium text-g2-accent">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : null}

    {relatedHref && post.data.relatedProductSlug ? (
      <section
        class="g2-section-subtle mx-auto mt-14 max-w-3xl rounded-2xl border border-g2-border p-6"
        aria-labelledby="related-product-heading"
      >
        <h2 id="related-product-heading" class="font-display text-lg font-semibold text-g2-text">
          Powiązany produkt
        </h2>
        <p class="mt-2 text-sm text-g2-muted">
          Ten artykuł odnosi się do rozwiązania produktowego — możesz przejść do strony produktu, aby zobaczyć moduły i
          model procesu.
        </p>
        <a class="g2-btn-primary mt-4 inline-flex" href={relatedHref}>
          Przejdź do produktu →
        </a>
      </section>
    ) : null}

    <nav class="mx-auto mt-12 max-w-3xl border-t border-g2-border pt-8 text-sm text-g2-muted" aria-label="Nawigacja po artykułach">
      <a href="/pl/artykuly/" class="font-medium text-g2-accent hover:underline">← Wszystkie artykuły</a>
    </nav>
  </article>
</MarketingLayout>
