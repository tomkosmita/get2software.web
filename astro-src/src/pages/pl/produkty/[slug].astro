---
/**
 * Szablon podstrony produktu (PL): hero (1 SVG) + persony + moduły + drugi mikro-diagram z JSON + integracje + FAQ.
 * Treść pochodzi z kolekcji `productBundles` (JSON); pole `modules[].body` może zawierać wiele akapitów (`\n\n`) -
 * renderujemy je w jednym `<p>` z `whitespace-pre-line`, żeby zachować odstępy bez wprowadzania HTML z treści.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { canonicalUrl } from '../../../lib/seo/site';
import { productSlugToRouteKey, routeMap } from '../../../lib/i18n/routes';
import ProductVisuals from '../../../components/illustrations/ProductVisuals.astro';

export async function getStaticPaths() {
  const bundles = await getCollection('productBundles');
  return bundles.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { data: entry.data.pl }
  }));
}

interface Props {
  data: import('astro:content').CollectionEntry<'productBundles'>['data']['pl'];
}

const { data } = Astro.props;

const pathname = `/pl/produkty/${Astro.params.slug}/`;
const hreflangPl = canonicalUrl(pathname);
const routeKey = productSlugToRouteKey(Astro.params.slug ?? '');
const enPath = routeKey ? routeMap[routeKey].en : '/en/products/';
const hreflangEn = canonicalUrl(enPath);
const alternateHref = enPath;

const ill = data.heroIllustration;
const slug = Astro.params.slug ?? '';
/** Stabilne id dla a11y: powiązanie grafiki hero z tytułem oraz diagramu focus z podpisem. */
const heroTitleId = `product-hero-title-${slug}`;
const focusCaptionId = `product-focus-caption-${slug}`;
/**
 * Jawna legenda kroków dla numerów 1..N na mikro-diagramie.
 * Dzięki temu grafika jest czytana jako konkretny proces biznesowy, a nie abstrakcyjny kształt.
 */
const focusStepsByProduct: Record<'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent', string[]> = {
  bhp: ['Dokument wydania', 'Kartoteka pracownika', 'Przypisanie kosztu', 'Rozliczenie w ERP'],
  fsm: ['Przyjęcie zgłoszenia', 'Plan pracy', 'Dokumentacja wykonania', 'Potwierdzenie klienta', 'Rozliczenie'],
  commissioning: ['Usterka w projekcie', 'Przypisanie wykonawcy', 'Sprawdzenie poprawki', 'Raport odbiorowy'],
  maintenance: ['Maszyna lub linia', 'Czas i części', 'Zamknięcie prac', 'Historia i wskaźniki'],
  fcm: ['Zgłoszenie z obiektu', 'Kategoria i priorytet', 'Przekazanie do realizacji', 'Przypisanie wykonawcy'],
  fcmrent: ['Zgłoszenie z obiektu', 'Rejestracja sprawy', 'Przekazanie wykonawcy', 'SLA i rozliczenie']
};
const focusSteps = focusStepsByProduct[ill];
const heroStepsByProduct: Record<'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent', string[]> = {
  bhp: ['Dokument wydania', 'Sprawdzenie stanu', 'Wydanie pracownikowi', 'Przypisanie kosztu', 'Rozliczenie w ERP'],
  fsm: ['Zgłoszenie', 'Plan pracy', 'Realizacja', 'Potwierdzenie klienta', 'Rozliczenie w ERP'],
  commissioning: ['Projekt i strefa', 'Zgłoszenie usterki', 'Przypisanie wykonawcy', 'Odbiór poprawki', 'Raport i archiwum'],
  maintenance: ['Maszyna lub linia', 'Zgłoszenie awarii', 'Prace serwisowe', 'Potwierdzenie wykonania', 'Historia utrzymania'],
  fcm: ['Zgłoszenie z obiektu', 'Kategoria i priorytet', 'Przekazanie do realizacji', 'Usunięcie usterki', 'Historia zgłoszenia'],
  fcmrent: ['Zgłoszenie najemcy', 'Rejestracja sprawy', 'Przekazanie wykonawcy', 'Realizacja', 'Rozliczenie']
};
const heroSteps = heroStepsByProduct[ill];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: data.heroTitle,
    description: data.seoDescription,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    url: hreflangPl,
    publisher: {
      '@type': 'Organization',
      name: 'get2software.com',
      url: canonicalUrl('/pl/')
    }
  }
];
---

<MarketingLayout
  locale="pl"
  title={data.seoTitle}
  description={data.seoDescription}
  pathname={pathname}
  hreflangPl={hreflangPl}
  hreflangEn={hreflangEn}
  alternateHref={alternateHref}
  active="products"
  structuredData={structuredData}
>
  <section class="g2-container py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-wider text-g2-accent">Produkt</p>
        <h1 id={heroTitleId} class="g2-heading-xl mt-2">{data.heroTitle}</h1>
        <p class="g2-prose mt-4 text-lg text-g2-muted">{data.heroLead}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/pl/kontakt/" class="g2-btn-primary">Umów demo</a>
          <a href="/pl/produkty/" class="g2-btn-secondary">Wszystkie produkty</a>
        </div>
      </div>
      <figure class="g2-glass p-6" aria-labelledby={heroTitleId}>
        <ProductVisuals product={ill} part="hero" class="h-auto w-full max-w-lg text-g2-text/35" />
        <figcaption class="mt-5 border-t border-g2-border pt-4">
          <ol class="grid gap-2 text-left text-sm text-g2-muted sm:grid-cols-2">
            {heroSteps.map((step, idx) => (
              <li class="flex items-start gap-2 rounded-md border border-g2-border/60 bg-white/40 px-3 py-2">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-g2-border text-[11px] font-semibold text-g2-text">
                  {idx + 1}
                </span>
                <span>{step}</span>
              </li>
            ))}
          </ol>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="g2-section-band py-14">
    <div class="g2-container">
      <h2 class="g2-heading-lg">Dla kogo</h2>
      <ul class="mt-6 grid gap-4 md:grid-cols-3">
        {data.personas.map((p) => (
          <li class="g2-glass rounded-xl p-4 text-base leading-relaxed text-g2-muted">{p}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="g2-container py-14">
    <h2 class="g2-heading-lg">Kluczowe moduły</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {data.modules.map((m) => (
        <article class="g2-glass p-6">
          <h3 class="font-display text-lg font-semibold text-g2-text">{m.title}</h3>
          <p class="mt-3 text-base leading-relaxed whitespace-pre-line text-g2-muted">{m.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="g2-container pb-14">
    <h2 class="g2-heading-lg">Kluczowy przepływ</h2>
    <p class="g2-prose mt-3 max-w-3xl">
      Diagram obok uzupełnia widok z hero: jeden łańcuch wartości od zdarzenia operacyjnego do domknięcia - zgodnie z
      modułami powyżej. Numery na osi kroków odpowiadają kolejności w podpisie.
    </p>
    <figure class="g2-glass mx-auto mt-8 max-w-3xl p-6">
      <ProductVisuals
        product={ill}
        part="focus"
        focusCaptionId={focusCaptionId}
        class="mx-auto h-auto w-full max-w-2xl text-g2-text/35"
      />
      <figcaption id={focusCaptionId} class="mt-6 border-t border-g2-border pt-4 text-center">
        <span class="font-display text-lg font-semibold text-g2-text">{data.focusDiagram.title}</span>
        <p class="g2-prose mx-auto mt-2 max-w-2xl text-base text-g2-muted">{data.focusDiagram.caption}</p>
        <ol class="mx-auto mt-4 grid max-w-2xl gap-2 text-left text-sm text-g2-muted sm:grid-cols-2">
          {focusSteps.map((step, idx) => (
            <li class="flex items-start gap-2 rounded-md border border-g2-border/60 bg-white/40 px-3 py-2">
              <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-g2-border text-[11px] font-semibold text-g2-text">
                {idx + 1}
              </span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </figcaption>
    </figure>
  </section>

  <section class="g2-section-subtle py-14">
    <div class="g2-container max-w-3xl">
      <h2 class="g2-heading-lg">Integracje</h2>
      <p class="g2-prose mt-3">{data.integrationsText}</p>
    </div>
  </section>

  {data.faqs && data.faqs.length > 0 && (
    <section class="g2-container py-14">
      <h2 class="g2-heading-lg">FAQ</h2>
      <dl class="mt-6 space-y-4">
        {data.faqs.map((f) => (
          <div class="g2-glass rounded-xl p-5">
            <dt class="font-medium text-g2-text">{f.question}</dt>
            <dd class="mt-2 text-sm text-g2-muted">{f.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  )}

  <section class="g2-container pb-20">
    <div class="g2-glass flex flex-col items-start gap-4 p-8 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-display text-xl font-semibold text-g2-text">Chcesz uporządkować ten proces w swojej firmie?</p>
        <p class="mt-1 text-sm text-g2-muted">Opisz obecną pracę operacyjną, a przygotujemy właściwy zakres wdrożenia.</p>
      </div>
      <a href="/pl/kontakt/" class="g2-btn-primary">Kontakt</a>
    </div>
  </section>
</MarketingLayout>
