---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import ContactForm from '../../../components/ContactForm.astro';
import { canonicalUrl } from '../../../lib/seo/site';
import { routeMap } from '../../../lib/i18n/routes';

const pathname = '/pl/kontakt/';
const title = 'Kontakt - get2software.com';
const description = 'Porozmawiajmy o wdrożeniu, integracji lub uporządkowaniu procesu operacyjnego w Twojej firmie.';
---

<MarketingLayout
  locale="pl"
  title={title}
  description={description}
  pathname={pathname}
  hreflangPl={canonicalUrl(pathname)}
  hreflangEn={canonicalUrl(routeMap.contact.en)}
  alternateHref={routeMap.contact.en}
  active="contact"
>
  <div class="g2-container py-14 md:py-20">
    <h1 class="g2-heading-xl">Kontakt</h1>
    <p class="g2-prose mt-4 max-w-2xl">
      Opisz proces, który chcesz uporządkować. Wracamy z propozycją podejścia, zakresem systemu i realnym kolejnym
      krokiem do wdrożenia.
    </p>
    <div class="mt-10 grid gap-10 lg:grid-cols-2">
      <ContactForm locale="pl" />
      <aside class="g2-glass p-6 text-sm text-g2-muted">
        <p class="font-display text-lg font-semibold text-g2-text">get2software.com</p>
        <p class="mt-3">
          E-mail: <a href="mailto:kontakt@get2software.com" class="text-g2-accent hover:underline">kontakt@get2software.com</a>
        </p>
        <p class="mt-4">
          Odpowiadamy na zapytania dotyczące wdrożeń, integracji i uporządkowania procesów operacyjnych. W wiadomości
          warto dodać branżę, skalę działania i system ERP, z którym pracuje firma.
        </p>
      </aside>
    </div>
  </div>
</MarketingLayout>
