---
/**
 * Product detail template (EN): hero, personas, module grid, diagrams, integrations, FAQ.
 * `productBundles` JSON drives content; `modules[].body` may use `\n\n` for paragraphs - single `<p>` with
 * `whitespace-pre-line` preserves spacing without embedding HTML inside copy.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { canonicalUrl } from '../../../lib/seo/site';
import { routeMap, productSlugToRouteKey } from '../../../lib/i18n/routes';
import ProductVisuals from '../../../components/illustrations/ProductVisuals.astro';

export async function getStaticPaths() {
  const bundles = await getCollection('productBundles');
  return bundles.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { data: entry.data.en }
  }));
}

interface Props {
  data: import('astro:content').CollectionEntry<'productBundles'>['data']['en'];
}

const { data } = Astro.props;

const pathname = `/en/products/${Astro.params.slug}/`;
const hreflangEn = canonicalUrl(pathname);
const routeKey = productSlugToRouteKey(Astro.params.slug ?? '');
const plPath = routeKey ? routeMap[routeKey].pl : '/pl/produkty/';
const hreflangPl = canonicalUrl(plPath);
const alternateHref = plPath;

const ill = data.heroIllustration;
const slug = Astro.params.slug ?? '';
const heroTitleId = `product-hero-title-${slug}`;
const focusCaptionId = `product-focus-caption-${slug}`;
const focusStepsByProduct: Record<'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent', string[]> = {
  bhp: ['Operational document', 'Employee record and balance', 'Cost-centre allocation', 'ERP settlement export'],
  fsm: ['Job intake', 'On-site execution and checklist', 'Time / cost / material capture', 'Customer sign-off', 'Close-out and ERP'],
  commissioning: ['On-site issue report', 'Contractor assignment', 'Quality verification', 'PDF handover report'],
  maintenance: ['Asset identification', 'Parts and labour capture', 'Work-order closure', 'History and KPI (MTTR)'],
  fcm: ['User ticket', 'Classification and priority', 'FM work order', 'Team / contractor assignment'],
  fcmrent: ['Tenant or property request', 'Work-order creation', 'Contractor execution', 'SLA and settlement']
};
const focusSteps = focusStepsByProduct[ill];
const heroStepsByProduct: Record<'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent', string[]> = {
  bhp: ['Movement document', 'Warehouse availability', 'Employee allocation', 'Cost-centre allocation', 'ERP settlement'],
  fsm: ['Service request', 'Planning', 'Field execution', 'Customer acceptance', 'ERP settlement'],
  commissioning: ['Project and zone', 'Issue logging', 'Contractor assignment', 'Quality verification', 'Report and archive'],
  maintenance: ['Asset identification', 'Service request', 'Work order', 'Execution control', 'Maintenance history'],
  fcm: ['User ticket', 'Classification', 'FM work order', 'Team execution', 'Closure and history'],
  fcmrent: ['Tenant request', 'Case registration', 'Contractor work order', 'SLA handling', 'Settlement']
};
const heroSteps = heroStepsByProduct[ill];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: data.heroTitle,
    description: data.seoDescription,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    url: hreflangEn,
    publisher: {
      '@type': 'Organization',
      name: 'get2software.com',
      url: canonicalUrl('/en/')
    }
  }
];
---

<MarketingLayout
  locale="en"
  title={data.seoTitle}
  description={data.seoDescription}
  pathname={pathname}
  hreflangPl={hreflangPl}
  hreflangEn={hreflangEn}
  alternateHref={alternateHref}
  active="products"
  structuredData={structuredData}
>
  <section class="g2-container py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-wider text-g2-accent">Product</p>
        <h1 id={heroTitleId} class="g2-heading-xl mt-2">{data.heroTitle}</h1>
        <p class="g2-prose mt-4 text-lg text-g2-muted">{data.heroLead}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/en/contact/" class="g2-btn-primary">Book a demo</a>
          <a href="/en/products/" class="g2-btn-secondary">All products</a>
        </div>
      </div>
      <figure class="g2-glass p-6" aria-labelledby={heroTitleId}>
        <ProductVisuals product={ill} part="hero" class="h-auto w-full max-w-lg text-g2-text/35" />
        <figcaption class="mt-5 border-t border-g2-border pt-4">
          <ol class="grid gap-2 text-left text-sm text-g2-muted sm:grid-cols-2">
            {heroSteps.map((step, idx) => (
              <li class="flex items-start gap-2 rounded-md border border-g2-border/60 bg-white/40 px-3 py-2">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-g2-border text-[11px] font-semibold text-g2-text">
                  {idx + 1}
                </span>
                <span>{step}</span>
              </li>
            ))}
          </ol>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="g2-section-band py-14">
    <div class="g2-container">
      <h2 class="g2-heading-lg">Who it’s for</h2>
      <ul class="mt-6 grid gap-4 md:grid-cols-3">
        {data.personas.map((p) => (
          <li class="g2-glass rounded-xl p-4 text-base leading-relaxed text-g2-muted">{p}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="g2-container py-14">
    <h2 class="g2-heading-lg">Key modules</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {data.modules.map((m) => (
        <article class="g2-glass p-6">
          <h3 class="font-display text-lg font-semibold text-g2-text">{m.title}</h3>
          <p class="mt-3 text-base leading-relaxed whitespace-pre-line text-g2-muted">{m.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="g2-container pb-14">
    <h2 class="g2-heading-lg">Core flow</h2>
    <p class="g2-prose mt-3 max-w-3xl">
      This diagram extends the hero view with a single value chain-from operational event to close-out-aligned with the
      modules above. Step numbers match the sequence explained in the caption.
    </p>
    <figure class="g2-glass mx-auto mt-8 max-w-3xl p-6">
      <ProductVisuals
        product={ill}
        part="focus"
        focusCaptionId={focusCaptionId}
        class="mx-auto h-auto w-full max-w-2xl text-g2-text/35"
      />
      <figcaption id={focusCaptionId} class="mt-6 border-t border-g2-border pt-4 text-center">
        <span class="font-display text-lg font-semibold text-g2-text">{data.focusDiagram.title}</span>
        <p class="g2-prose mx-auto mt-2 max-w-2xl text-base text-g2-muted">{data.focusDiagram.caption}</p>
        <ol class="mx-auto mt-4 grid max-w-2xl gap-2 text-left text-sm text-g2-muted sm:grid-cols-2">
          {focusSteps.map((step, idx) => (
            <li class="flex items-start gap-2 rounded-md border border-g2-border/60 bg-white/40 px-3 py-2">
              <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-g2-border text-[11px] font-semibold text-g2-text">
                {idx + 1}
              </span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </figcaption>
    </figure>
  </section>

  <section class="g2-section-subtle py-14">
    <div class="g2-container max-w-3xl">
      <h2 class="g2-heading-lg">Integrations</h2>
      <p class="g2-prose mt-3">{data.integrationsText}</p>
    </div>
  </section>

  {data.faqs && data.faqs.length > 0 && (
    <section class="g2-container py-14">
      <h2 class="g2-heading-lg">FAQ</h2>
      <dl class="mt-6 space-y-4">
        {data.faqs.map((f) => (
          <div class="g2-glass rounded-xl p-5">
            <dt class="font-medium text-g2-text">{f.question}</dt>
            <dd class="mt-2 text-sm text-g2-muted">{f.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  )}

  <section class="g2-container pb-20">
    <div class="g2-glass flex flex-col items-start gap-4 p-8 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-display text-xl font-semibold text-g2-text">Want to bring this process under control?</p>
        <p class="mt-1 text-sm text-g2-muted">Describe the way your team works today and we will shape the right rollout scope.</p>
      </div>
      <a href="/en/contact/" class="g2-btn-primary">Contact</a>
    </div>
  </section>
</MarketingLayout>
