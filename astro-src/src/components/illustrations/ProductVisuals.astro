---
/**
 * Grafiki wektorowe (SVG) per produkt - styl monoline + akcent brand.
 * Prop `part`: hero (duży) lub sekcje diagramów 1–5 zgodnie z planem dokumentacji.
 */
type ProductKey = 'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent';
type Part =
  | 'hero'
  | 's1'
  | 's2'
  | 's3'
  | 's4'
  | 's5';

interface Props {
  product: ProductKey;
  part: Part;
  class?: string;
}

const { product, part, class: className = '' } = Astro.props;

const stroke = 'currentColor';
const acc = '#2dd4bf';
const acc2 = '#a78bfa';
---

{product === 'bhp' && part === 'hero' && (
  <svg class={className} viewBox="0 0 480 280" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect x="24" y="40" width="160" height="200" rx="12" stroke={stroke} stroke-width="2" class="text-white/40" />
    <text x="104" y="32" text-anchor="middle" class="fill-g2-muted text-[11px]">Centralny</text>
    <rect x="200" y="60" width="120" height="72" rx="10" stroke={acc} stroke-width="2" />
    <text x="260" y="52" text-anchor="middle" class="fill-g2-muted text-[11px]">Wirtualny</text>
    <rect x="200" y="160" width="120" height="72" rx="10" stroke={acc2} stroke-width="2" />
    <text x="260" y="152" text-anchor="middle" class="fill-g2-muted text-[11px]">Pracownik</text>
    <path d="M184 120h16M184 196h16" stroke={stroke} stroke-width="2" class="text-white/50" marker-end="url(#a)" />
