---
/**
 * Wszystkie diagramy są teraz uproszczonym flow głównego procesu produktu.
 *
 * Zasada layoutu:
 * - Każdy diagram to oś kroków 1→N (bez dekoracji i „losowych” kształtów).
 * - Każdy krok to prostokątny węzeł z ikoną domenową (dokument, zlecenie, ERP, SLA itp.).
 * - Strzałki pokazują kierunek procesu; numeracja jest zgodna z listą kroków pod diagramem w szablonie strony.
 * - Hero i Focus to ten sam język wizualny; Focus ma krótszy łańcuch (bardziej syntetyczny).
 */
type ProductKey = 'bhp' | 'fsm' | 'commissioning' | 'maintenance' | 'fcm' | 'fcmrent';
type Part = 'hero' | 'focus';
type StepKind =
  | 'document'
  | 'warehouse'
  | 'person'
  | 'cost'
  | 'erp'
  | 'ticket'
  | 'plan'
  | 'mobile'
  | 'sign'
  | 'project'
  | 'camera'
  | 'team'
  | 'quality'
  | 'archive'
  | 'asset'
  | 'workorder'
  | 'classify'
  | 'sla';

interface Props {
  product: ProductKey;
  part: Part;
  class?: string;
  /** Dla focus: a11y przez powiązanie SVG z figcaption. */
  focusCaptionId?: string;
}

const { product, part, class: className = '', focusCaptionId } = Astro.props;

/** Linia bazowa o stałym kontraście (czytelna także na jasnym tle). */
const stroke = '#1f2937';
/** Linia pomocnicza ikon. */
const strokeSoft = '#64748b';
/** Akcent marki. */
const acc = 'oklch(60% 0.13 200)';
/** Drugi akcent marki. */
const acc2 = 'oklch(56% 0.11 262)';

const isFocusA11y = part === 'focus' && Boolean(focusCaptionId);

/**
 * Mapa głównych flow per produkt.
 * Hero: pełny uproszczony proces biznesowy.
 * Focus: skrócony rdzeń procesu z tej samej strony produktu.
 */
const productFlows: Record<ProductKey, { hero: StepKind[]; focus: StepKind[] }> = {
  bhp: {
    hero: ['document', 'warehouse', 'person', 'cost', 'erp'],
    focus: ['document', 'person', 'cost', 'erp']
  },
  fsm: {
    hero: ['ticket', 'plan', 'mobile', 'sign', 'erp'],
    focus: ['plan', 'mobile', 'cost', 'sign', 'erp']
  },
  commissioning: {
    hero: ['project', 'camera', 'team', 'quality', 'archive'],
    focus: ['camera', 'team', 'quality', 'archive']
  },
  maintenance: {
    hero: ['asset', 'ticket', 'workorder', 'quality', 'archive'],
    focus: ['asset', 'workorder', 'quality', 'archive']
  },
  fcm: {
    hero: ['ticket', 'classify', 'workorder', 'team', 'archive'],
    focus: ['ticket', 'classify', 'team', 'sla']
  },
  fcmrent: {
    hero: ['asset', 'ticket', 'workorder', 'team', 'sla'],
    focus: ['ticket', 'workorder', 'team', 'sla']
  }
};

const steps = productFlows[product][part];
const nodeW = part === 'hero' ? 96 : 102;
const nodeH = part === 'hero' ? 78 : 82;
const gap = 30;
const padX = 28;
const topY = part === 'hero' ? 72 : 58;
const centerY = topY + nodeH / 2;
const vbW = padX * 2 + steps.length * nodeW + (steps.length - 1) * gap;
const vbH = part === 'hero' ? 192 : 176;
const markerId = `${product}-${part}-flow-arrow`;
---

<svg
  class={className}
  viewBox={`0 0 ${vbW} ${vbH}`}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role={isFocusA11y ? 'img' : undefined}
  aria-hidden={isFocusA11y ? undefined : true}
  aria-labelledby={isFocusA11y ? focusCaptionId : undefined}
>
  <defs>
    <marker id={markerId} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
      <path d="M0 0 L8 4 L0 8 Z" fill={stroke} opacity="0.75" />
    </marker>
  </defs>

  {steps.map((_, idx) => {
    if (idx === steps.length - 1) return null;
    const x1 = padX + idx * (nodeW + gap) + nodeW;
    const x2 = padX + (idx + 1) * (nodeW + gap) - 6;
    return (
      <path
        d={`M${x1} ${centerY}H${x2}`}
        stroke={stroke}
        stroke-width="2.2"
        marker-end={`url(#${markerId})`}
        opacity="0.86"
      />
    );
  })}

  {steps.map((step, idx) => {
    const x = padX + idx * (nodeW + gap);
    const iconColor = idx % 2 === 0 ? acc : acc2;
    return (
      <g>
        <rect x={x} y={topY} width={nodeW} height={nodeH} rx="12" stroke={stroke} stroke-width="2.4" fill="#ffffff" fill-opacity="0.7" />
        <circle cx={x + nodeW / 2} cy={30} r="11" fill="#ffffff" stroke={iconColor} stroke-width="2" />
        <text x={x + nodeW / 2} y={34} text-anchor="middle" font-size="11" font-weight="700" fill={stroke}>
          {idx + 1}
        </text>

        {/* Ikony domenowe: każdy typ kroku ma własny symbol, bez tekstu językowego w SVG. */}
        {step === 'document' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={`M${x + 30} ${topY + 22}h32l8 8v30h-40z`} />
            <path d={`M${x + 62} ${topY + 22}v8h8`} />
            <path d={`M${x + 36} ${topY + 44}h22M${x + 36} ${topY + 54}h18`} />
          </g>
        )}
        {step === 'warehouse' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <path d={`M${x + 28} ${topY + 28}h40v30h-40z`} />
            <path d={`M${x + 28} ${topY + 38}h40M${x + 41} ${topY + 28}v30M${x + 55} ${topY + 28}v30`} />
          </g>
        )}
        {step === 'person' && (
          <g stroke={iconColor} stroke-width="2.2" stroke-linecap="round">
            <circle cx={x + 48} cy={topY + 34} r="10" />
            <path d={`M${x + 32} ${topY + 60}c8-10 24-10 32 0`} />
          </g>
        )}
        {step === 'cost' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <path d={`M${x + 28} ${topY + 60}v-14M${x + 44} ${topY + 60}v-24M${x + 60} ${topY + 60}v-34`} />
            <path d={`M${x + 24} ${topY + 60}h44`} />
          </g>
        )}
        {step === 'erp' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <ellipse cx={x + 48} cy={topY + 30} rx="20" ry="7" />
            <path d={`M${x + 28} ${topY + 30}v20c0 4 9 7 20 7s20-3 20-7v-20`} />
            <path d={`M${x + 28} ${topY + 40}c0 4 9 7 20 7s20-3 20-7`} />
          </g>
        )}
        {step === 'ticket' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <path d={`M${x + 26} ${topY + 28}h44v10c-4 0-6 3-6 6s2 6 6 6v10h-44v-10c4 0 6-3 6-6s-2-6-6-6z`} />
          </g>
        )}
        {step === 'plan' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <rect x={x + 28} y={topY + 26} width="40" height="34" rx="6" />
            <path d={`M${x + 28} ${topY + 38}h40M${x + 38} ${topY + 22}v8M${x + 58} ${topY + 22}v8`} />
          </g>
        )}
        {step === 'mobile' && (
          <g stroke={iconColor} stroke-width="2.2" stroke-linecap="round">
            <rect x={x + 34} y={topY + 22} width="28" height="40" rx="7" />
            <circle cx={x + 48} cy={topY + 56} r="1.6" fill={iconColor} />
          </g>
        )}
        {step === 'sign' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={`M${x + 30} ${topY + 58}h36`} />
            <path d={`M${x + 34} ${topY + 46}c7-9 14-9 20 0`} />
            <path d={`M${x + 52} ${topY + 46}l9-10`} />
          </g>
        )}
        {step === 'project' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <path d={`M${x + 28} ${topY + 34}h16l4-6h22v30h-42z`} />
            <path d={`M${x + 28} ${topY + 42}h42`} />
          </g>
        )}
        {step === 'camera' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <rect x={x + 28} y={topY + 30} width="40" height="26" rx="5" />
            <circle cx={x + 48} cy={topY + 43} r="7" />
            <path d={`M${x + 36} ${topY + 30}l4-5h16l4 5`} />
          </g>
        )}
        {step === 'team' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <circle cx={x + 40} cy={topY + 35} r="7" />
            <circle cx={x + 56} cy={topY + 35} r="7" />
            <path d={`M${x + 30} ${topY + 56}c6-7 14-7 20 0M${x + 46} ${topY + 56}c6-7 14-7 20 0`} />
          </g>
        )}
        {step === 'quality' && (
          <g stroke={iconColor} stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx={x + 48} cy={topY + 43} r="14" />
            <path d={`M${x + 41} ${topY + 43}l5 5 10-12`} />
          </g>
        )}
        {step === 'archive' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <rect x={x + 28} y={topY + 32} width="40" height="24" rx="4" />
            <path d={`M${x + 24} ${topY + 32}h48v-8h-48zM${x + 42} ${topY + 44}h12`} />
          </g>
        )}
        {step === 'asset' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <rect x={x + 30} y={topY + 28} width="10" height="10" />
            <rect x={x + 56} y={topY + 28} width="10" height="10" />
            <rect x={x + 30} y={topY + 52} width="10" height="10" />
            <path d={`M${x + 46} ${topY + 34}h6M${x + 46} ${topY + 56}h20`} />
          </g>
        )}
        {step === 'workorder' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <rect x={x + 30} y={topY + 26} width="36" height="34" rx="5" />
            <path d={`M${x + 38} ${topY + 22}h20M${x + 38} ${topY + 38}h20M${x + 38} ${topY + 48}h14`} />
          </g>
        )}
        {step === 'classify' && (
          <g stroke={iconColor} stroke-width="2" stroke-linecap="round">
            <circle cx={x + 34} cy={topY + 44} r="5" />
            <circle cx={x + 62} cy={topY + 34} r="5" />
            <circle cx={x + 62} cy={topY + 54} r="5" />
            <path d={`M${x + 39} ${topY + 44}h18M${x + 52} ${topY + 41}l6-5M${x + 52} ${topY + 47}l6 5`} />
          </g>
        )}
        {step === 'sla' && (
          <g stroke={iconColor} stroke-width="2.2" stroke-linecap="round">
            <circle cx={x + 48} cy={topY + 43} r="15" />
            <path d={`M${x + 48} ${topY + 34}v10l8 5`} />
          </g>
        )}

        {/* Delikatna linia bazowa pod ikoną poprawia czytelność środka węzła. */}
        <path d={`M${x + 24} ${topY + nodeH - 14}H${x + nodeW - 24}`} stroke={strokeSoft} stroke-width="1.4" opacity="0.35" />
      </g>
    );
  })}
</svg>
