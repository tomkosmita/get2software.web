---
/**
 * Lekka karuzela / ticker z nazwami systemów ERP.
 * Cel biznesowy: w pierwszym ekranie szybko zakotwiczyć markę strony w realnych systemach,
 * które klient zna z rynku, bez budowania fałszywej obietnicy „gotowych konektorów do wszystkiego”.
 *
 * Layout:
 * - Dwa identyczne tory z tym samym zestawem nazw dają płynny efekt nieskończonego przesuwu bez JavaScript.
 * - Każda nazwa siedzi w „pill” z obramowaniem i lekkim cieniem, aby pas wyglądał jak baner referencyjny,
 *   a nie jak zwykła lista tekstowa.
 * - overflow hidden odcina kopię listy poza viewportem; animujemy tylko track, nie pojedyncze elementy.
 */
type Props = {
  systems: string[];
  locale: 'pl' | 'en';
  class?: string;
};

const { systems, locale, class: className = '' } = Astro.props;

const sectionLabel =
  locale === 'pl'
    ? 'Systemy ERP, z którymi najczęściej planujemy integrację projektową'
    : 'ERP systems we most often plan project integrations with';
---

<section class:list={['g2-glass overflow-hidden p-4 md:p-5', className]} aria-label={sectionLabel}>
  <!-- Baner: same nazwy ERP w tickerze — bez dodatkowego nagłówka wizualnego (etykieta tylko w aria-label sekcji). -->
  <div class="erp-carousel" data-layout="erp-name-ticker">
    <div class="erp-carousel__track">
      {[...systems, ...systems].map((system, idx) => (
        <span class="erp-carousel__pill" aria-hidden={idx >= systems.length}>
          {system}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .erp-carousel {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
  }

  .erp-carousel__track {
    display: flex;
    width: max-content;
    gap: 0.85rem;
    animation: erp-carousel-scroll 24s linear infinite;
  }

  .erp-carousel__pill {
    flex: 0 0 auto;
    border: 1px solid color-mix(in oklab, var(--color-g2-border) 86%, white);
    background:
      linear-gradient(180deg, color-mix(in oklab, white 96%, var(--color-g2-accent) 4%), color-mix(in oklab, white 98%, var(--color-g2-accent-2) 2%));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
    border-radius: 999px;
    color: var(--color-g2-text);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    padding: 0.8rem 1.15rem;
    white-space: nowrap;
  }

  @keyframes erp-carousel-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.425rem));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .erp-carousel__track {
      animation-duration: 0.01ms;
      animation-iteration-count: 1;
      transform: translateX(0);
    }
  }
</style>
