---
import type { Locale } from '../lib/i18n/routes';
import { routeMap } from '../lib/i18n/routes';

type Props = {
  locale: Locale;
  /** Aktywny klucz trasy dla podświetlenia (opcjonalnie). */
  active?: 'home' | 'about' | 'products' | 'integrations' | 'support' | 'news' | 'careers' | 'contact';
  /** Pełny URL (ścieżka) do tej samej strony w drugim języku - hreflang UX w menu. */
  alternateHref: string;
};

const { locale, active, alternateHref } = Astro.props;

const t =
  locale === 'pl'
    ? {
        home: 'Start',
        about: 'O nas',
        products: 'Produkty',
        integrations: 'Integracje',
        /** Pozycja menu: utrzymanie systemów po wdrożeniu (spójna etykieta z podstroną /pl/wsparcie-systemow/). */
        support: 'Wsparcie',
        news: 'Aktualności',
        careers: 'Kariera',
        contact: 'Kontakt',
        langSwitch: 'English',
        productBhp: 'get2_BHPRent',
        productFsm: 'get2_FSM',
        productComm: 'get2_Commissioning',
        productMaint: 'get2_Maintenance',
        productFcm: 'get2_FCM',
        productFcmRent: 'get2_FCMRent',
        /** Etykieta przycisku hamburgera gdy panel jest zamknięty (dostępność). */
        openMenu: 'Otwórz menu',
        /** Etykieta przycisku gdy panel jest otwarty - zamknięcie tym samym kontrolerem. */
        closeMenu: 'Zamknij menu'
      }
    : {
        home: 'Home',
        about: 'About',
        products: 'Products',
        integrations: 'Integrations',
        support: 'Support',
        news: 'News',
        careers: 'Careers',
        contact: 'Contact',
        langSwitch: 'Polski',
        productBhp: 'get2_BHPRent',
        productFsm: 'get2_FSM',
        productComm: 'get2_Commissioning',
        productMaint: 'get2_Maintenance',
        productFcm: 'get2_FCM',
        productFcmRent: 'get2_FCMRent',
        openMenu: 'Open menu',
        closeMenu: 'Close menu'
      };

const home = routeMap.home[locale];
const about = routeMap.about[locale];
const products = routeMap.products[locale];
const integrations = routeMap.integrations[locale];
const support = routeMap.support[locale];
const news = routeMap.news[locale];
const careers = routeMap.careers[locale];
const contact = routeMap.contact[locale];
const pBhp = routeMap.productBhp[locale];
const pFsm = routeMap.productFsm[locale];
const pComm = routeMap.productComm[locale];
const pMaint = routeMap.productMaint[locale];
const pFcm = routeMap.productFcm[locale];
const pFcmRent = routeMap.productFcmRent[locale];

/** Druga wersja językowa - ten sam klucz strony co bieżąca (ustawiane per-page w przyszłości); tu uproszczenie: mapowanie po pathname z props parent. */
const otherLocale: Locale = locale === 'pl' ? 'en' : 'pl';

const navAria = locale === 'pl' ? 'Główne' : 'Main';

/** Klasy powtarzalnego linku nawigacji mobilnej - hover: „plama” g2-hover (jasny motyw, nie white/5 z dark UI). */
const mobileNavLink = 'flex w-full rounded-lg px-3 py-3 text-sm font-medium transition hover:bg-g2-hover';
const mobileProductLink =
  'flex w-full rounded-lg px-3 py-2.5 text-sm text-g2-muted transition hover:bg-g2-hover hover:text-g2-text';
---

<!--
  sticky: przyklejony pasek + jednocześnie kontekst pozycjonowania dla panelu absolute (bez osobnego relative).
-->
<header
  class="sticky top-0 z-50 border-b border-g2-border bg-g2-bg/80 backdrop-blur-lg"
  data-component="site-header"
>
  <!--
    Layout: pierwszy rząd = logo + desktop nav / przycisk mobile.
    Panel mobilny jest poza flow wysokości paska (absolute top-full), żeby sticky nie „skakał”.
  -->
  <div class="g2-container flex h-16 items-center justify-between gap-4 lg:h-[4.25rem]">
    <a
      href={home}
      class="font-display text-lg font-semibold tracking-tight text-g2-text hover:text-g2-accent transition"
    >
      get2<span class="text-g2-accent">software</span>
    </a>

    <!-- Menu desktop - dropdown Produkty zgodnie z planem IA (bez zmian zachowania). -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label={navAria}>
      <a
        href={home}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'home' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.home}
      </a>
      <a
        href={about}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'about' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.about}
      </a>

      <div class="relative group">
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
            active === 'products' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          {t.products}
          <span class="text-xs opacity-70" aria-hidden="true">▾</span>
        </button>
        <!-- Dropdown: pozycjonowanie absolutne; group-hover pokazuje listę produktów (desktop). -->
        <div
          class="invisible absolute left-0 top-full z-50 min-w-[14rem] pt-1 opacity-0 transition group-hover:visible group-hover:opacity-100"
        >
          <div class="g2-glass flex flex-col gap-0.5 p-2 shadow-g2-dropdown">
            <a href={pBhp} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productBhp}
            </a>
            <a href={pFsm} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productFsm}
            </a>
            <a href={pComm} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productComm}
            </a>
            <a href={pMaint} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productMaint}
            </a>
            <a href={pFcm} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productFcm}
            </a>
            <a href={pFcmRent} class="rounded-lg px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text">
              {t.productFcmRent}
            </a>
            <a
              href={products}
              class="mt-1 border-t border-g2-border pt-2 text-center text-xs font-medium text-g2-accent hover:underline"
            >
              {locale === 'pl' ? 'Wszystkie produkty →' : 'All products →'}
            </a>
          </div>
        </div>
      </div>

      <a
        href={integrations}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'integrations' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.integrations}
      </a>
      <a
        href={support}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'support' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.support}
      </a>
      <a
        href={news}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'news' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.news}
      </a>
      <a
        href={careers}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-g2-hover',
          active === 'careers' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
        ]}
      >
        {t.careers}
      </a>
      <a
        href={contact}
        class:list={[
          'ml-2 rounded-xl bg-g2-accent px-4 py-2 text-sm font-semibold text-g2-on-accent hover:brightness-105',
          active === 'contact' ? 'ring-2 ring-g2-accent/35' : ''
        ]}
      >
        {t.contact}
      </a>
      <a
        href={alternateHref}
        class="ml-2 rounded-lg border border-g2-glass-border px-3 py-2 text-sm text-g2-muted hover:bg-g2-hover hover:text-g2-text"
        hreflang={otherLocale}
        lang={otherLocale}
      >
        {t.langSwitch}
      </a>
    </nav>

    <!-- Mobile: tylko toggle hamburger - język i pełna nawigacja w panelu pod headerem. -->
    <div class="flex items-center lg:hidden">
      <button
        type="button"
        id="g2-mobile-nav-toggle"
        class="g2-mobile-nav-toggle flex h-11 w-11 items-center justify-center rounded-lg border border-g2-glass-border text-g2-text transition hover:bg-g2-hover"
        aria-expanded="false"
        aria-controls="g2-mobile-nav-panel"
        aria-label={t.openMenu}
      >
        <!-- Ikona inline: trzy linie → X przy aria-expanded=true (animacja w scoped style). -->
        <svg class="g2-mobile-nav-icon size-6" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <rect class="g2-hamburger-bar g2-hamburger-bar--top" x="3" y="6" width="18" height="2" rx="1" fill="currentColor"
          ></rect>
          <rect class="g2-hamburger-bar g2-hamburger-bar--mid" x="3" y="11" width="18" height="2" rx="1" fill="currentColor"
          ></rect>
          <rect class="g2-hamburger-bar g2-hamburger-bar--bot" x="3" y="16" width="18" height="2" rx="1" fill="currentColor"
          ></rect>
        </svg>
      </button>
    </div>
  </div>

  <!--
    Panel mobilny: pełna szerokość viewportu względem headera, pod sticky paskiem.
    max-height + overflow-y: długa lista produktów nie wychodzi poza ekran (100dvh − wysokość paska).
    Panel nad treścią: pełne bg-g2-bg (bez alpha) - blur na półprzezroczystym tle zawsze zostawiał „duch” strony pod spodem; tu priorytet to czytelność. Cień oddziela warstwę wizualnie.
  -->
  <div
    id="g2-mobile-nav-panel"
    class="absolute left-0 right-0 top-full z-40 hidden border-b border-g2-border bg-g2-bg shadow-g2-dropdown lg:hidden"
    role="region"
    aria-label={locale === 'pl' ? 'Menu nawigacji mobilnej' : 'Mobile navigation menu'}
    aria-hidden="true"
    hidden
  >
    <div
      class="g2-container max-h-[min(70vh,calc(100dvh-4rem))] overflow-y-auto py-4"
    >
      <nav class="flex flex-col gap-0.5" aria-label={navAria}>
        <a
          href={home}
          class:list={[mobileNavLink, active === 'home' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text']}
        >
          {t.home}
        </a>
        <a
          href={about}
          class:list={[mobileNavLink, active === 'about' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text']}
        >
          {t.about}
        </a>

        <!-- Akordeon Produkty: ta sama IA co desktop (bez zmian slugów). -->
        <div class="border-t border-g2-border pt-1">
          <button
            type="button"
            id="g2-mobile-products-btn"
            class:list={[
              'flex w-full items-center justify-between rounded-lg px-3 py-3 text-left text-sm font-medium transition hover:bg-g2-hover',
              active === 'products' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
            ]}
            aria-expanded="false"
            aria-controls="g2-mobile-products-region"
          >
            <span>{t.products}</span>
            <span class="text-xs opacity-70 transition-transform g2-mobile-products-chevron" aria-hidden="true">▾</span>
          </button>
          <div
            id="g2-mobile-products-region"
            class="hidden flex flex-col gap-0.5 border-t border-g2-border/60 pb-2 pt-1"
            role="region"
            aria-labelledby="g2-mobile-products-btn"
            aria-hidden="true"
            hidden
          >
            <a href={pBhp} class={mobileProductLink}>{t.productBhp}</a>
            <a href={pFsm} class={mobileProductLink}>{t.productFsm}</a>
            <a href={pComm} class={mobileProductLink}>{t.productComm}</a>
            <a href={pMaint} class={mobileProductLink}>{t.productMaint}</a>
            <a href={pFcm} class={mobileProductLink}>{t.productFcm}</a>
            <a href={pFcmRent} class={mobileProductLink}>{t.productFcmRent}</a>
            <a
              href={products}
              class="mt-1 border-t border-g2-border px-3 pt-3 text-center text-xs font-medium text-g2-accent hover:underline"
            >
              {locale === 'pl' ? 'Wszystkie produkty →' : 'All products →'}
            </a>
          </div>
        </div>

        <a
          href={integrations}
          class:list={[
            mobileNavLink,
            active === 'integrations' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text'
          ]}
        >
          {t.integrations}
        </a>
        <a
          href={support}
          class:list={[mobileNavLink, active === 'support' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text']}
        >
          {t.support}
        </a>
        <a
          href={news}
          class:list={[mobileNavLink, active === 'news' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text']}
        >
          {t.news}
        </a>
        <a
          href={careers}
          class:list={[mobileNavLink, active === 'careers' ? 'text-g2-accent' : 'text-g2-muted hover:text-g2-text']}
        >
          {t.careers}
        </a>

        <a
          href={contact}
          class:list={[
            'mt-2 w-full rounded-xl bg-g2-accent px-4 py-3 text-center text-sm font-semibold text-g2-on-accent hover:brightness-105',
            active === 'contact' ? 'ring-2 ring-g2-accent/35' : ''
          ]}
        >
          {t.contact}
        </a>
        <a
          href={alternateHref}
          class="mt-2 w-full rounded-lg border border-g2-glass-border px-3 py-3 text-center text-sm text-g2-muted transition hover:bg-g2-hover hover:text-g2-text"
          hreflang={otherLocale}
          lang={otherLocale}
        >
          {t.langSwitch}
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  /*
   * Animacja hamburger → X na przycisku mobilnym.
   * Oparty wyłącznie o atrybut aria-expanded (bez dodatkowej biblioteki ikon).
   */
  #g2-mobile-nav-toggle[aria-expanded='true'] .g2-hamburger-bar--top {
    transform: translateY(5px) rotate(45deg);
    transform-origin: center;
  }
  #g2-mobile-nav-toggle[aria-expanded='true'] .g2-hamburger-bar--mid {
    opacity: 0;
  }
  #g2-mobile-nav-toggle[aria-expanded='true'] .g2-hamburger-bar--bot {
    transform: translateY(-5px) rotate(-45deg);
    transform-origin: center;
  }
  #g2-mobile-nav-toggle .g2-hamburger-bar {
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  #g2-mobile-products-btn[aria-expanded='true'] .g2-mobile-products-chevron {
    transform: rotate(180deg);
  }
</style>

<script is:inline define:vars={{ openMenuLabel: t.openMenu, closeMenuLabel: t.closeMenu }}>
  (function () {
    const header = document.querySelector('header[data-component="site-header"]');
    if (!header) return;
    const toggle = header.querySelector('#g2-mobile-nav-toggle');
    const panel = header.querySelector('#g2-mobile-nav-panel');
    const productsBtn = header.querySelector('#g2-mobile-products-btn');
    const productsRegion = header.querySelector('#g2-mobile-products-region');
    if (!toggle || !panel) return;

    /** Zapis poprzedniego overflow na <html> - przywracamy przy zamknięciu (scroll lock bez „zacięcia”). */
    let htmlOverflowBefore = '';

    function lockBackgroundScroll() {
      const root = document.documentElement;
      if (!htmlOverflowBefore) htmlOverflowBefore = root.style.overflow || '';
      root.style.overflow = 'hidden';
    }

    function unlockBackgroundScroll() {
      document.documentElement.style.overflow = htmlOverflowBefore;
      htmlOverflowBefore = '';
    }

    function navIsOpen() {
      return toggle.getAttribute('aria-expanded') === 'true';
    }

    /** Zamyka akordeon produktów - wywoływane przy zamknięciu całego menu (spójny stan po ponownym otwarciu). */
    function resetProductsAccordion() {
      if (!productsBtn || !productsRegion) return;
      productsBtn.setAttribute('aria-expanded', 'false');
      productsRegion.classList.add('hidden');
      productsRegion.setAttribute('hidden', '');
      productsRegion.setAttribute('aria-hidden', 'true');
    }

    /**
     * Główny przełącznik panelu mobilnego.
     * @param {boolean} open - czy panel ma być widoczny
     * @param {{ restoreFocusToToggle?: boolean }} opts - przy Esc / klik poza header: fokus wraca na hamburger
     */
    function setNavOpen(open, opts) {
      const restoreFocusToToggle = opts && opts.restoreFocusToToggle;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? closeMenuLabel : openMenuLabel);
      if (open) {
        panel.classList.remove('hidden');
        panel.removeAttribute('hidden');
        panel.setAttribute('aria-hidden', 'false');
        lockBackgroundScroll();
        queueMicrotask(function () {
          const first = panel.querySelector('a[href]');
          if (first && first instanceof HTMLElement) first.focus();
        });
      } else {
        panel.classList.add('hidden');
        panel.setAttribute('hidden', '');
        panel.setAttribute('aria-hidden', 'true');
        unlockBackgroundScroll();
        resetProductsAccordion();
        if (restoreFocusToToggle) toggle.focus();
      }
    }

    function closeNavIfOpen(opts) {
      if (!navIsOpen()) return;
      setNavOpen(false, opts || {});
    }

    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      setNavOpen(!navIsOpen(), {});
    });

    if (productsBtn && productsRegion) {
      productsBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        const expanded = productsBtn.getAttribute('aria-expanded') === 'true';
        const next = !expanded;
        productsBtn.setAttribute('aria-expanded', next ? 'true' : 'false');
        if (next) {
          productsRegion.classList.remove('hidden');
          productsRegion.removeAttribute('hidden');
          productsRegion.setAttribute('aria-hidden', 'false');
        } else {
          productsRegion.classList.add('hidden');
          productsRegion.setAttribute('hidden', '');
          productsRegion.setAttribute('aria-hidden', 'true');
        }
      });
    }

    panel.addEventListener('click', function (e) {
      const t = e.target;
      if (!(t instanceof Element)) return;
      const link = t.closest('a[href]');
      if (link && panel.contains(link)) closeNavIfOpen({});
    });

    document.addEventListener(
      'keydown',
      function (e) {
        if (e.key === 'Escape' && navIsOpen()) {
          e.preventDefault();
          closeNavIfOpen({ restoreFocusToToggle: true });
        }
      },
      true
    );

    /** Zamknięcie po tapnięciu poza header (bez przyciemniania - tylko UX). */
    document.addEventListener('click', function (e) {
      if (!navIsOpen()) return;
      var path = e.composedPath();
      if (path.indexOf(header) !== -1) return;
      closeNavIfOpen({ restoreFocusToToggle: true });
    });

    window.addEventListener('pagehide', function () {
      unlockBackgroundScroll();
    });
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') unlockBackgroundScroll();
    });
  })();
</script>
